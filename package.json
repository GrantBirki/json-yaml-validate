{
  "name": "json-yaml-validate-action",
  "version": "0.0.0",
  "private": true,
  "description": "A GitHub Action to quickly validate JSON and YAML files in a repository",
  "main": "lib/main.js",
  "scripts": {
    "format": "prettier --write '**/*.js'",
    "format-check": "prettier --check '**/*.js'",
    "lint": "eslint src/**/*.js",
    "package": "ncc build src/main.js -o dist --source-map --license licenses.txt",
    "test": "LOCAL_ACTIONS_CI_TEST=true jest; test_status=$?; node scripts/coverage-badge.js; exit $test_status",
    "ci-test": "LOCAL_ACTIONS_CI_TEST=true jest",
    "all": "npm run format && npm run lint && npm run package",
    "bundle": "npm run format && npm run package"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grantbirki/json-yaml-validate.git"
  },
  "keywords": [
    "actions",
    "ci",
    "json",
    "yaml",
    "validate"
  ],
  "author": "Grant Birkinbine",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "ajv": "^8.20.0",
    "ajv-draft-04": "^1.0.0",
    "ajv-formats": "^3.0.1",
    "glob": "^13.0.6",
    "ignore": "^7.0.5",
    "yaml": "^2.8.4",
    "yaml-schema-validator": "^1.2.3"
  },
  "jest": {
    "coverageReporters": [
      "json-summary",
      "text",
      "lcov"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "./src/**"
    ],
    "moduleNameMapper": {
      "^@actions/core$": "<rootDir>/test-helpers/actions-core.js"
    },
    "coverageThreshold": {
      "global": {
        "lines": 100
      }
    }
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@eslint/js": "^10.0.1",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.3.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3"
  },
  "overrides": {
    "brace-expansion": "^1.1.14"
  }
}
